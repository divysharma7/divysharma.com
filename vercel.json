{
	"functions": {
		"api/health.js": {
			"maxDuration": 10
		}
	},
	"routes": [
		{
			"src": "/spotify",
			"status": 308,
			"headers": {
				"Location": "https://open.spotify.com/user/31wan4heyahmjpej4evvpzwzjnji"
			}
		},
		{
			"src": "/twitter",
			"status": 308,
			"headers": {
				"Location": "https://twitter.com/Divy_Sharma6"
			}
		},
		{
			"src": "/twt",
			"status": 308,
			"headers": {
				"Location": "https://twitter.com/Divy_Sharma6"
			}
		},
		{
			"src": "/ig",
			"status": 308,
			"headers": {
				"Location": "https://www.instagram.com/divy.sharma9/"
			}
		},
		{
			"src": "/instagram",
			"status": 308,
			"headers": {
				"Location": "https://www.instagram.com/divy.sharma9/"
			}
		},
		{
			"src": "/ponder/(.*)",
			"dest": "https://ponder.vercel.app/$1"
		},
		{
			"src": "/spotifyactivity/(.*)",
			"dest": "https://spotact-website.vercel.app/$1"
		},
		{
			"src": "/api/(.*)",
			"headers": {
				"Access-Control-Allow-Credentials": "true",
				"Access-Control-Allow-Origin": "*",
				"Access-Control-Allow-Methods": "GET,OPTIONS,PATCH,DELETE,POST,PUT",
				"Access-Control-Allow-Headers": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
			},
			"continue": true
		},
		{
			"src": "/(.*)",
			"dest": "/index.html"
		}
	],
	"github": {
		"autoAlias": true,
		"enabled": true,
		"silent": true
	},
	"trailingSlash": false,
	"public": false
}